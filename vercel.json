{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Content-Security-Policy",
          "value": "base-uri 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=31536000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "BR"
        }
      ],
      "status": 307,
      "headers": {
        "Location": "/pt"
      }
    },
    {
      "src": "/",
      "status": 307,
      "headers": {
        "Location": "/en"
      }
    },
    { "src": "/api/ai/credits", "dest": "/api/ai/generate" },
    { "src": "/api/admin/ai-credits", "dest": "/api/ai/generate" },
    { "handle": "filesystem" },
    { "src": "/(pt/sobre|en/about|pt/modelos(?:/curriculo-primeiro-emprego)?|en/templates(?:/first-job-resume)?|pt/ferramentas/gerador-resumo-profissional|en/tools/professional-summary-generator|pt/(?:termos|privacidade|contato|cookies)|en/(?:terms|privacy|contact|cookies)|pt/blog(?:/.*)?|en/blog(?:/.*)?|blog(?:/.*)?|pricing|terms|privacy|contact|cookies|templates|payment/(?:success|cancel)|login|signin|signup|auth/google/callback|verify-email|forgot-password|reset-password|profile|settings|admin(?:/.*)?|dashboard(?:/.*)?)/?", "dest": "/index.html" }
  ]
}
